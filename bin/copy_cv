#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SOURCE="$ROOT_DIR/CV/main.pdf"
TARGET_DIR="$ROOT_DIR/assets/pdf"
TARGET="$TARGET_DIR/CV.pdf"

if [[ ! -f "$SOURCE" ]]; then
  echo "Source PDF not found: $SOURCE" >&2
  exit 1
fi

mkdir -p "$TARGET_DIR"
cp "$SOURCE" "$TARGET"

echo "Copied $SOURCE to $TARGET"
